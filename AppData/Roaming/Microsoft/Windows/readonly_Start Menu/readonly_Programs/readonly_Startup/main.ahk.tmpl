{{ if eq .chezmoi.os "windows" -}}
RunScoop(app)
{
    appdata_dir := EnvGet("AppData")
    user_dir := EnvGet("userprofile")
    scoop_apps_dir := appdata_dir . "/Microsoft/Windows/Start Menu/Programs/Scoop Apps"
    Run(scoop_apps_dir . "/" . app . ".lnk", user_dir, "Max")
}
{{ if lookPath "glazewm" -}}
Run("glazewm", {{ .chezmoi.homeDir | quote }}, "Hide")
{{ end -}}
{{ if and (eq .chezmoi.hostname "nuc") (lookPath "deskflow-core") -}}
Run("deskflow-core client", , "Hide")
{{ end -}}
{{ if lookPath "aria2c" -}}
Run("{{ joinPath .chezmoi.homeDir "scoop" "apps" "aria2" "current" "aria2c.exe" }} --enable-rpc", {{ joinPath .chezmoi.homeDir "Downloads" | quote }}, "Hide")
{{ end -}}
{{ if lookPath "espansod" -}}
Run("{{ joinPath .chezmoi.homeDir "scoop" "apps" "espanso" "current" "espansod.exe" }} start", {{ .chezmoi.homeDir | quote }}, "Hide")
{{ end -}}
{{ $win_gpg_agent := joinPath .chezmoi.homeDir "scoop" "apps" "win-gpg-agent" "current" "agent-gui.exe" }}
{{ if stat $win_gpg_agent -}}
Run({{ $win_gpg_agent | quote }}, , "Hide")
{{ end -}}
{{ if and (eq .chezmoi.hostname "nuc") (lookPath "alist") -}}
Run("alist start", , "Hide")
{{ end -}}
{{ if lookPath "mpd" -}}
Run("mpd {{ joinPath (env "appdata") "mpd" "mpd.conf"}}", {{ .chezmoi.homeDir | quote }}, "Hide")
{{ end -}}
{{ if lookPath "kdeconnect-cli" -}}
Run("{{ joinPath .chezmoi.homeDir "scoop" "apps" "kdeconnect" "current" "bin" "kdeconnectd.exe" }}", {{ .chezmoi.homeDir | quote }}, "Hide")
{{ end -}}
{{ $powertoys := joinPath .chezmoi.homeDir "scoop" "apps" "powertoys" "current" "powertoys.exe" -}}
{{ if stat $powertoys -}}
Run("{{ $powertoys }}", {{ .chezmoi.homeDir | quote }}, "Hide")
{{ end -}}
{{ $flow := joinPath .chezmoi.homeDir "scoop" "apps" "flow-launcher" "current" "Flow.Launcher.exe" -}}
{{ if stat $flow -}}
Run("{{ $flow }}", {{ .chezmoi.homeDir | quote }}, "Hide")
{{ end -}}
{{ if and (lookPath "wt") (lookPath "pwsh") -}}
RunScoop("Windows Terminal")
{{ end -}}
{{ if stat "C:/Program Files/Mozilla Firefox/firefox.exe" -}}
Run("C:/Program Files/Mozilla Firefox/firefox.exe", , "Max")
{{ else if lookPath "brave" -}}
Run("D:/scoop/apps/brave/current/brave.exe", "c:/users/user" , "Max")
{{ end -}}
{{ if lookPath "code" -}}
Run("code", {{ .chezmoi.homeDir | quote }})
{{ end -}}
{{ end -}}
