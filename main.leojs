  "tnodes": {
    "User.20260226221459.1": "# This is an example of a macro that you might use to execute a command.\n# This will add the command to history.\nSet-PSReadLineKeyHandler -Key Ctrl+g `\n                         -BriefDescription Lazygit `\n                         -LongDescription \"Run lazygit\" `\n                         -ScriptBlock {\n    [Microsoft.PowerShell.PSConsoleReadLine]::RevertLine()\n    [Microsoft.PowerShell.PSConsoleReadLine]::Insert(\"lazygit\")\n    [Microsoft.PowerShell.PSConsoleReadLine]::AcceptLine()\n}",
    "User.20260221193859.1": "{{ if lookPath \"gpg-connect-agent\" -}}\nRun(\"gpg-connect-agent /bye\", , \"Hide\")\n{{ end -}}\n",
    "User.20260221180517.1": "{{ if and (eq .chezmoi.hostname \"nuc\") (lookPath \"runemacs\") -}}\n; Run(\"runemacs --daemon\", EnvGet(\"userprofile\"), \"Hide\")\n{{ end -}}\n",
    "zxc.20260203193056.1": "{{ if lookPath \"mcfly\" -}}\n# mcfly\nInvoke-Expression -Command $(mcfly init powershell | out-string)\n{{ end -}}",
    "zxc.20260125142149.1": "@tabwidth 4\nall:\n\t@others\n",
