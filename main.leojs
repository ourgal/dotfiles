    "zxc.20260201142202.1": "{\n    \"$help\": \"https://aka.ms/terminal-documentation\",\n    \"$schema\": \"https://aka.ms/terminal-profiles-schema\",\n    \"actions\": [],\n    \"copyFormatting\": \"none\",\n    \"copyOnSelect\": false,\n    \"defaultProfile\": \"{574e775e-4f2a-5b96-ac1e-a2962a402336}\",\n    \"keybindings\": \n    [\n        {\n            \"id\": \"Terminal.CopyToClipboard\",\n            \"keys\": \"ctrl+c\"\n        },\n        {\n            \"id\": \"Terminal.PasteFromClipboard\",\n            \"keys\": \"ctrl+v\"\n        },\n        {\n            \"id\": \"Terminal.DuplicatePaneAuto\",\n            \"keys\": \"alt+shift+d\"\n        }\n    ],\n    \"newTabMenu\": \n    [\n        {\n            \"type\": \"remainingProfiles\"\n        }\n    ],\n    \"profiles\": \n    {\n        \"defaults\": {},\n        \"list\": \n        [\n            {\n                \"guid\": \"{574e775e-4f2a-5b96-ac1e-a2962a402336}\",\n                << common >>\n                \"name\": \"PowerShell\",\n                \"source\": \"Windows.Terminal.PowershellCore\"\n            },\n            {\n                \"commandline\": \"%SystemRoot%\\\\System32\\\\cmd.exe\",\n                << common >>\n                \"guid\": \"{0caa0dad-35be-5f56-a8ff-afceeeaa6101}\",\n                \"name\": \"Command Prompt\"\n            },\n            {\n                \"commandline\": \"%SystemRoot%\\\\System32\\\\WindowsPowerShell\\\\v1.0\\\\powershell.exe\",\n                << common >>\n                \"guid\": \"{61c54bbd-c2c6-5271-96e7-009a87ff44bf}\",\n                \"name\": \"Windows PowerShell\"\n            },\n            {\n                \"commandline\": \"%USERPROFILE%\\\\.local\\\\bin\\\\xonsh.exe\",\n                << common >>\n                \"guid\": \"{1039824d-f5da-468d-856d-d7373d40325e}\",\n                \"name\": \"Xonsh\"\n            },\n            {\n                \"commandline\": \"%USERPROFILE%\\\\scoop\\\\apps\\\\git\\\\current\\\\bin\\\\bash.exe -i -l\",\n                << common >>\n                \"guid\": \"{8f5e00bb-5ac4-4e63-8538-5bcbbf827559}\",\n                \"name\": \"Git Bash\"\n            },\n            {\n                \"commandline\": \"%USERPROFILE%\\\\scoop\\\\shims\\\\msys2.cmd\",\n                << common >>\n                \"guid\": \"{f60ba69c-a957-410c-a1c6-8b7484ee591c}\",\n                \"name\": \"MSYS\"\n            },\n            {\n                \"commandline\": \"%USERPROFILE%\\\\scoop\\\\shims\\\\nu.exe\",\n                << common >>\n                \"guid\": \"{2a38cb46-e594-415f-9cce-1e3d1b313ee9}\",\n                \"name\": \"Nu shell\"\n            },\n            {\n                \"commandline\": \"%USERPROFILE%\\\\scoop\\\\shims\\\\yori.exe\",\n                << common >>\n                \"guid\": \"{90a23420-d58c-4627-9e4d-6ab897661ef7}\",\n                \"name\": \"Yori\"\n            },\n            {\n                \"guid\": \"{b453ae62-4e3d-5e58-b989-0a998ec441b8}\",\n                << common >>\n                \"name\": \"Azure Cloud Shell\",\n                \"source\": \"Windows.Terminal.Azure\"\n            }\n        ]\n    },\n    \"schemes\": [],\n    \"themes\": []\n}\n\n",
